# Environnement – Système CSI AMA Maradi
# Copier ce fichier en .env et renseigner les valeurs

# ── Application ──────────────────────────────────────────────
APP_NAME=Système CSI Direct Aid Maradi
APP_ENV=development
APP_URL=http://localhost:8182/csi_ama_maradi
APP_TIMEZONE=Africa/Niamey

# ── Base de données MySQL ─────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=csi_ama
DB_USER=root
DB_PASS=

# ── XAMPP : si mot de passe root défini, le mettre ici ────────
# DB_PASS=votre_mot_de_passe
