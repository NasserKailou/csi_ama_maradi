# ============================================================
# Configuration Environnement – Système CSI AMA
# Copier ce fichier en .env et remplir les valeurs
# IMPORTANT : Ne jamais committer .env dans git !
# ============================================================

APP_ENV=development
BASE_URL=http://localhost

# Base de données MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=csi_ama
DB_USER=root
DB_PASS=

# En production, définir APP_ENV=production
# APP_ENV=production
# BASE_URL=https://votre-domaine.com
