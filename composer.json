{
    "name": "csi/ama-maradi",
    "description": "Système de Gestion du Centre de Santé Intégré AMA Maradi",
    "type": "project",
    "require": {
        "php": ">=8.0",
        "tecnickcom/tcpdf": "^6.6"
    },
    "autoload": {
        "classmap": ["core/", "modules/pdf/"]
    },
    "config": {
        "optimize-autoloader": true,
        "vendor-dir": "vendor"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
